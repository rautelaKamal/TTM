# PostgreSQL — used by Prisma and the API server
DATABASE_URL="postgresql://ttm:ttm_dev@localhost:5432/ttm?schema=public"

# NextAuth.js
NEXTAUTH_SECRET="generate-a-32-char-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Express API
API_PORT=4000
API_URL="http://localhost:4000"

# JWT — used by Express to verify tokens from NextAuth
JWT_SECRET="same-value-as-NEXTAUTH_SECRET"

# CORS — allowed origins for the API
CORS_ORIGIN="http://localhost:3000"

# Next.js public env — exposed to the browser for client-side API calls
NEXT_PUBLIC_API_URL="http://localhost:4000"
